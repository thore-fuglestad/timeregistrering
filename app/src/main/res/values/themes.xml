<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Base.Theme.Timeregistrering" parent="Theme.Material3.Light.NoActionBar">
        <!-- Mørkeblå som primærfarge — brukes på knapper, FAB, markerte elementer -->
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryVariant">@color/colorPrimaryVariant</item>
        <item name="colorOnPrimary">@color/colorOnPrimary</item>

        <!-- Ren hvit bakgrunn -->
        <item name="android:colorBackground">@color/colorBackground</item>
        <item name="android:windowBackground">@color/colorBackground</item>
        <item name="colorSurface">@color/colorSurface</item>
        <item name="colorOnSurface">@color/colorOnSurface</item>

        <!-- Avrundede knapper (8dp) -->
        <item name="materialButtonStyle">@style/Widget.App.Button</item>

        <!-- Kort: lysegrå bakgrunn, ingen ramme -->
        <item name="materialCardViewStyle">@style/Widget.App.CardView</item>
    </style>

    <style name="Theme.Timeregistrering" parent="Base.Theme.Timeregistrering" />

    <!-- Knapper: mørkeblå med avrundede hjørner -->
    <style name="Widget.App.Button" parent="Widget.Material3.Button">
        <item name="cornerRadius">8dp</item>
        <item name="backgroundTint">@color/colorPrimary</item>
    </style>

    <!-- Outlined-knapper (filterknappene) -->
    <style name="Widget.App.Button.Outlined" parent="Widget.Material3.Button.OutlinedButton">
        <item name="cornerRadius">8dp</item>
        <item name="strokeColor">@color/colorPrimary</item>
        <item name="android:textColor">@color/colorPrimary</item>
    </style>

    <!-- Kort: lysegrå bakgrunn, ingen synlig ramme -->
    <style name="Widget.App.CardView" parent="Widget.Material3.CardView.Elevated">
        <item name="cardBackgroundColor">@color/colorCardBackground</item>
        <item name="cardElevation">0dp</item>
        <item name="strokeWidth">0dp</item>
        <item name="cardCornerRadius">8dp</item>
    </style>
</resources>
