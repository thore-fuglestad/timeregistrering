<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Dato"
        android:textStyle="bold"/>

    <!-- Klikk åpner DatePickerDialog -->
    <EditText
        android:id="@+id/etDato"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:focusable="false"
        android:clickable="true"
        android:layout_marginBottom="16dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Starttid"
        android:textStyle="bold"/>

    <!-- Klikk åpner TimePickerDialog -->
    <EditText
        android:id="@+id/etStartTid"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:focusable="false"
        android:clickable="true"
        android:layout_marginBottom="16dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Sluttid"
        android:textStyle="bold"/>

    <!-- Klikk åpner TimePickerDialog -->
    <EditText
        android:id="@+id/etSluttTid"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:focusable="false"
        android:clickable="true"
        android:layout_marginBottom="16dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Justering (minutter, kan være negativ)"
        android:textStyle="bold"/>

    <EditText
        android:id="@+id/etJustering"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:inputType="numberSigned"
        android:layout_marginBottom="24dp"/>

    <Button
        android:id="@+id/btnLagre"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Lagre"
        android:layout_marginBottom="8dp"/>

    <Button
        android:id="@+id/btnSlett"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Slett vakt"
        style="@style/Widget.App.Button.Outlined"
        android:textColor="@android:color/holo_red_dark"
        app:strokeColor="@android:color/holo_red_dark"/>

</LinearLayout>
