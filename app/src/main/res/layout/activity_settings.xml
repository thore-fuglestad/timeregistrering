<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <!-- Header — samme stil som hovedskjermen -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/colorPrimary"
        android:padding="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Innstillinger"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_centerVertical="true"/>

        <!-- Tilbake-knapp -->
        <ImageButton
            android:id="@+id/btnTilbake"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            android:contentDescription="Lukk"/>

    </RelativeLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Seksjon: normal arbeidstid -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Normal arbeidstid per vakt"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="Jobb (timer)"
                app:endIconMode="none"
                android:layout_marginEnd="8dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etNormalTimerJobb"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="number"/>

            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="Privat (timer)"
                app:endIconMode="none"
                android:layout_marginEnd="12dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etNormalTimerPrivat"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="number"/>

            </com.google.android.material.textfield.TextInputLayout>

            <Button
                android:id="@+id/btnLagreTimer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Lagre"/>

        </LinearLayout>


        <!-- Seksjon: generer testdata -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Generer testdata"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Genererer vakter for alle hverdager i valgt måned med tilfeldig varighet rundt normal arbeidstid."
            android:textSize="13sp"
            android:layout_marginBottom="12dp"/>

        <Spinner
            android:id="@+id/spinnerTestKategori"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:entries="@array/kategorier"
            android:background="@drawable/spinner_background"
            android:layout_marginBottom="12dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="Velg måned"
                app:endIconMode="none"
                android:layout_marginEnd="12dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etTestMnd"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:focusable="false"
                    android:clickable="true"/>

            </com.google.android.material.textfield.TextInputLayout>

            <Button
                android:id="@+id/btnGenererTestdata"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Generer"
                android:layout_marginEnd="8dp"/>

            <Button
                android:id="@+id/btnSlettTestdata"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Slett"
                app:strokeColor="@android:color/holo_red_dark"
                android:textColor="@android:color/holo_red_dark"
                style="@style/Widget.App.Button.Outlined"/>

        </LinearLayout>

        <!-- Seksjon: eksport -->
        <!-- Seksjon: eksport og import -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Eksport / Import"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Eksporter eller importer vakter som CSV-fil."
            android:textSize="13sp"
            android:layout_marginBottom="8dp"/>

        <Spinner
            android:id="@+id/spinnerEksportKategori"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:entries="@array/kategorier_filter"
            android:background="@drawable/spinner_background"
            android:layout_marginBottom="12dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <Button
                android:id="@+id/btnEksporterAlt"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="Eksporter alt"
                android:textColor="#FFFFFF"
                android:backgroundTint="#00695C"
                android:layout_marginEnd="4dp"/>

            <Button
                android:id="@+id/btnEksporterMnd"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="Eksporter måned"
                android:textColor="#FFFFFF"
                android:backgroundTint="#00695C"
                android:layout_marginEnd="4dp"/>

            <Button
                android:id="@+id/btnImporter"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="Importer"
                android:textColor="#FFFFFF"
                android:backgroundTint="#E65100"/>

        </LinearLayout>

        <!-- Seksjon: slett all data -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Farlig sone"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@android:color/holo_red_dark"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="8dp"/>

        <Button
            android:id="@+id/btnSlettAlt"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Slett all data"
            android:backgroundTint="@color/colorStoppRed"
            android:textColor="#FFFFFF"/>

    </LinearLayout>

</LinearLayout>
